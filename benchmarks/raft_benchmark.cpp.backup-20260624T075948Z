using namespace std::chrono_literals;

class TemporaryDirectory final {
 public:
  TemporaryDirectory() {
    const auto stamp = std::chrono::steady_clock::now()
                           .time_since_epoch()
                           .count();
    path_ = std::filesystem::temp_directory_path() /
            ("nebulakv-raft-benchmark-" + std::to_string(stamp));
    std::filesystem::create_directories(path_);
  }

  ~TemporaryDirectory() {
    std::error_code error;
    std::filesystem::remove_all(path_, error);
  }

  [[nodiscard]] const std::filesystem::path& path() const noexcept {
    return path_;
  }

 private:
  std::filesystem::path path_;
};

struct BenchmarkNode {
  RaftStorage storage;
  DurableKeyValueStateMachine state_machine;
  InMemoryRaftTransport transport;
  RaftNode node;

  BenchmarkNode(const std::filesystem::path& root, RaftNodeOptions options,
                InMemoryRaftNetwork& network)
      : storage{root / options.node_id / "raft"},
        state_machine{DurableStateMachineOptions{root / options.node_id}},
        transport{options.node_id, network},
        node{std::move(options), storage, state_machine, transport} {}
};

[[nodiscard]] std::vector<Peer> peers_for(const std::string& local) {
  std::vector<Peer> peers;
  for (const std::string id : {"node-1", "node-2", "node-3"}) {
    if (id != local) {
      peers.push_back({id, id + ":5001"});
    }
  }
  return peers;
}

[[nodiscard]] RaftNodeOptions options_for(const std::string& id,
                                          const std::uint64_t seed) {
  RaftNodeOptions options;
  options.node_id = id;
  options.peers = peers_for(id);
  options.election_timeout_min = 150ms;
  options.election_timeout_max = 250ms;
  options.heartbeat_interval = 30ms;
  options.rpc_timeout = 50ms;
  options.random_seed = seed;
  options.snapshot_threshold_entries = 100'000U;
  return options;
}

void benchmark_raft_majority_commit(benchmark::State& state) {
  TemporaryDirectory directory;
  InMemoryRaftNetwork network;
  BenchmarkNode first{directory.path(), options_for("node-1", 1U), network};
  BenchmarkNode second{directory.path(), options_for("node-2", 2U), network};
  BenchmarkNode third{directory.path(), options_for("node-3", 3U), network};
  network.register_endpoint("node-1", first.node);
  network.register_endpoint("node-2", second.node);
  network.register_endpoint("node-3", third.node);
  first.node.trigger_election();
  if (!first.node.is_leader()) {
    state.SkipWithError("failed to elect benchmark leader");
    return;
  }

  std::uint64_t sequence = 0U;
  for (auto _ : state) {
    static_cast<void>(_);
    const auto result = first.node.submit(
        {CommandType::Put, "benchmark:" + std::to_string(sequence++),
         "value"},
        2s);
    if (!result.committed()) {
      state.SkipWithError(result.message.c_str());
      break;
    }
  }
  state.SetItemsProcessed(state.iterations());
  state.counters["commit_index"] =
      static_cast<double>(first.node.status().commit_index);
  state.counters["followers"] = 2.0;
}

void benchmark_raft_quorum_read_barrier(benchmark::State& state) {
  TemporaryDirectory directory;
  InMemoryRaftNetwork network;
  BenchmarkNode first{directory.path(), options_for("node-1", 11U), network};
  BenchmarkNode second{directory.path(), options_for("node-2", 12U), network};
  BenchmarkNode third{directory.path(), options_for("node-3", 13U), network};
  network.register_endpoint("node-1", first.node);
  network.register_endpoint("node-2", second.node);
  network.register_endpoint("node-3", third.node);
  first.node.trigger_election();
  if (!first.node.is_leader()) {
    state.SkipWithError("failed to elect benchmark leader");
    return;
  }

  for (auto _ : state) {
    static_cast<void>(_);
    const bool confirmed =
        first.node.confirm_leadership(std::chrono::steady_clock::now() + 2s);
    benchmark::DoNotOptimize(confirmed);
    if (!confirmed) {
      state.SkipWithError("failed to confirm Raft quorum");
      break;
    }
  }
  state.SetItemsProcessed(state.iterations());
  state.counters["followers"] = 2.0;
}

BENCHMARK(benchmark_raft_majority_commit)->Unit(benchmark::kMicrosecond);
BENCHMARK(benchmark_raft_quorum_read_barrier)->Unit(benchmark::kMicrosecond);

}  // namespace
